<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>Label</key>
	<string>com.intentional.daemon</string>

	<key>Program</key>
	<string>/usr/local/libexec/intentional-daemon</string>

	<key>MachServices</key>
	<dict>
		<key>com.intentional.daemon.xpc</key>
		<true/>
	</dict>

	<key>KeepAlive</key>
	<true/>

	<key>RunAtLoad</key>
	<true/>

	<key>WatchPaths</key>
	<array>
		<string>/etc/hosts</string>
	</array>

	<key>StandardOutPath</key>
	<string>/var/log/intentional-daemon.log</string>

	<key>StandardErrorPath</key>
	<string>/var/log/intentional-daemon.log</string>
</dict>
</plist>
